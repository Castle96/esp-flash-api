# ---------------------------------------------------------------------------
# Jarvis Pi Gateway - Environment Configuration
# The Pi is a pure API gateway. Inference can run across multiple nodes.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Upstream service hosts (can be different machines)
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://PI5_8GB_IP:11434
STT_HOST=http://PI4_STT_IP:8001
TTS_HOST=http://PI4_TTS_IP:8002

# ---------------------------------------------------------------------------
# LLM
# For Pi5 8GB, use a small quantized Gemma 4 variant loaded in Ollama.
# Examples: gemma4:latest, gemma4:4b, or your locally-tagged quant name.
# ---------------------------------------------------------------------------
OLLAMA_MODEL=gemma4

SYSTEM_PROMPT=You are Jarvis: a concise, calm, confident, and action-oriented AI assistant for a technically proficient user in embedded systems, home lab automation, and Linux orchestration. Be concise (1-3 sentences). Start with action or confirmation. Use short confirmations like "Understood." or "Working on it." Provide production-ready code and commands.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
