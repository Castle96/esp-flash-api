# ---------------------------------------------------------------------------
# Jarvis Backend — Environment Configuration
# Copy to .env and fill in real values before starting.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Ollama (remote LLM — your big machine)
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://OLLAMA_HOST_IP:11434

# CPU now: gemma3:27b (~18GB RAM, excellent quality)
# GPU later: llama3.3:70b (~42GB RAM, best available in 64GB)
OLLAMA_MODEL=gemma3:27b

SYSTEM_PROMPT=You are Jarvis: a concise, calm, confident, and action-oriented AI assistant for a technically proficient user in embedded systems, home lab automation, and Linux orchestration. Be concise (1-3 sentences). Start with action or confirmation. Use short confirmations like "Understood." or "Working on it." Provide production-ready code and commands.

# ---------------------------------------------------------------------------
# Speech-to-text — Systran/faster-whisper-large-v3
# ---------------------------------------------------------------------------
WHISPER_MODEL=Systran/faster-whisper-large-v3

# CPU now:
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# GPU later (swap these two lines):
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16

# ---------------------------------------------------------------------------
# Text-to-speech
# ---------------------------------------------------------------------------

# CPU now — Kokoro (hexgrad/Kokoro-82M, ONNX, ~500ms latency)
TTS_ENGINE=kokoro
KOKORO_VOICE=bm_george
# Available voices:
#   bm_george  — British male, authoritative (recommended for Jarvis)
#   bm_lewis   — British male, calm
#   am_adam    — American male, deep
#   am_michael — American male, neutral
#   af_bella   — American female, warm
#   af_sarah   — American female, neutral
#   bf_emma    — British female, crisp
KOKORO_SPEED=1.0

# GPU later — XTTS v2 (coqui/XTTS-v2, voice cloning, ~250ms on CUDA)
# Swap TTS_ENGINE and provide a 3-6s WAV reference clip for your target voice.
# TTS_ENGINE=xtts
# XTTS_VOICE_REF=/voices/jarvis_reference.wav

# Legacy fallback
# TTS_ENGINE=piper
# PIPER_VOICE=/voices/jarvis_voice.onnx

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
