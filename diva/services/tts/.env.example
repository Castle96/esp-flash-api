# TTS microservice - runs on voice node (port 8002)

# Pi-friendly CPU default - Kokoro (hexgrad/Kokoro-82M)
TTS_ENGINE=kokoro
KOKORO_VOICE=bm_george
# Voices: bm_george, bm_lewis, am_adam, am_michael, af_bella, af_sarah, bf_emma
KOKORO_SPEED=1.0

# GPU later - XTTS v2 (coqui/XTTS-v2, voice cloning)
# TTS_ENGINE=xtts
# XTTS_VOICE_REF=/voices/jarvis_reference.wav
