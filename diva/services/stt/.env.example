# STT microservice - runs on voice node (port 8001)
# Pi 4 (4GB) default profile:
# - Use smaller model to avoid OOM and high latency.
WHISPER_MODEL=Systran/faster-whisper-small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Higher-quality option (Pi 5 8GB):
# WHISPER_MODEL=Systran/faster-whisper-medium

# GPU later (swap these):
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
